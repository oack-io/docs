{
  "$schema": "https://mintlify.com/docs.json",
  "name": "Oack Docs",
  "theme": "mint",
  "colors": {
    "primary": "#16A34A",
    "light": "#07C983",
    "dark": "#15803D"
  },
  "favicon": "/favicon.svg",
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:support@oack.io"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://app.oack.io"
    }
  },
  "footer": {
    "socials": {
      "github": "https://github.com/oack-io",
      "linkedin": "https://linkedin.com/in/gregory-komissarov"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Getting Started",
            "pages": ["index", "quickstart"]
          },
          {
            "group": "Monitoring",
            "pages": [
              "monitoring/http-monitoring",
              "monitoring/health-rules",
              "monitoring/ssl-domain-expiration",
              "monitoring/tcp-telemetry",
              "monitoring/probe-aggregation",
              "monitoring/performance-percentiles"
            ]
          },
          {
            "group": "Alerting",
            "pages": ["alerting/channels", "alerting/behavior"]
          },
          {
            "group": "Sharing & Analytics",
            "pages": [
              "sharing/probe-sharing",
              "sharing/redaction-groups",
              "analytics/reliability-metrics"
            ]
          },
          {
            "group": "Network Checker",
            "pages": ["checker/overview", "checker/installation"]
          },
          {
            "group": "Integrations",
            "pages": ["integrations/mcp", "integrations/rest-api"]
          },
          {
            "group": "Account",
            "pages": ["account/roles-and-permissions", "account/plans"]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Website",
          "href": "https://oack.io",
          "icon": "globe"
        },
        {
          "anchor": "Status",
          "href": "https://self-status.oack.io",
          "icon": "signal"
        }
      ]
    }
  }
}
